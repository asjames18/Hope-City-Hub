# AI model used by Supabase Edge Function proxy (optional override)
# Optional: VITE_HF_MODEL=HuggingFaceTB/SmolLM3-3B (default)
VITE_HF_MODEL=

# Supabase (optional - for database-backed config & events)
# Create a project at https://supabase.com, run supabase/migrations/001_initial.sql in SQL Editor, then add:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# For AI prayers, also deploy `supabase/functions/hf-generate` and set secret:
# HUGGINGFACE_API_TOKEN=hf_xxx
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=



supabase secrets set HUGGINGFACE_API_TOKEN=hf_xxx --project-ref jphjdbzpbpuhycmklybf
