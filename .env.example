# AI assistant (Hope AI bubble)
# In production: shown when Supabase URL+anon are set, unless VITE_ENABLE_AI=false.
# Set VITE_ENABLE_AI=false to hide the assistant even with Supabase configured.
VITE_ENABLE_AI=

# Supabase (optional - for database-backed config & events)
# Create a project at https://supabase.com, run supabase/migrations/001_initial.sql in SQL Editor, then add:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# For AI prayers, also deploy `supabase/functions/hf-generate` and set one or more secrets:
# AI_PROVIDER_ORDER=gemini,deepseek,anthropic,openai
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash-lite
# DEEPSEEK_API_KEY=...
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-haiku-4-5
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-5-mini
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
